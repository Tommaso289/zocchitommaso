int rosso = 13;
int giallo = 12;
int verde = 11;

void setup() {
  pinMode(rosso, OUTPUT);
  pinMode(giallo, OUTPUT);
  pinMode(verde, OUTPUT);
}

void loop() {
  // ROSSO
  digitalWrite(rosso, HIGH);
  delay(5000);
  digitalWrite(rosso, LOW);

  // VERDE
  digitalWrite(verde, HIGH);
  delay(5000);
  digitalWrite(verde, LOW);

  // GIALLO
  digitalWrite(giallo, HIGH);
  delay(2000);
  digitalWrite(giallo, LOW);
}
    delay(3000);
  }
